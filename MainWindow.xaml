<Window x:Class="LingosolveStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LingosolveStudio"
        xmlns:controls="clr-namespace:LingosolveStudio.Controls"
        Icon="./Resources/LingosolveStudio.ico"
        Title="Lingosolve Studio 1.0" Height="700" Width="1300" MinWidth="900" MinHeight="500"
        Loaded="Window_Loaded" Closed="Window_Closed" AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="Image">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- MoveThumb Template -->
        <ControlTemplate x:Key="MoveThumbTemplate" TargetType="{x:Type controls:MoveThumb}">
            <Rectangle Fill="Transparent"/>
        </ControlTemplate>

        <!-- ResizeDecorator Template -->
        <ControlTemplate x:Key="ResizeDecoratorTemplate" TargetType="{x:Type Control}">
            <Grid>
                <controls:ResizeThumb Height="2" Cursor="SizeNS" Margin="0 -4 0 0" VerticalAlignment="Top" HorizontalAlignment="Stretch"/>
                <controls:ResizeThumb Width="7" Height="7" Cursor="SizeNS" Margin="0 -6 0 0" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                <controls:ResizeThumb Width="2" Cursor="SizeWE" Margin="-4 0 0 0" VerticalAlignment="Stretch" HorizontalAlignment="Left"/>
                <controls:ResizeThumb Width="7" Height="7" Cursor="SizeWE" Margin="-6 0 0 0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <controls:ResizeThumb Width="2" Cursor="SizeWE" Margin="0 0 -4 0" VerticalAlignment="Stretch" HorizontalAlignment="Right"/>
                <controls:ResizeThumb Width="7" Height="7" Cursor="SizeWE" Margin="0 0 -6 0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                <controls:ResizeThumb Height="2" Cursor="SizeNS" Margin="0 0 0 -4" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"/>
                <controls:ResizeThumb Width="7" Height="7" Cursor="SizeNS" Margin="0 0 0 -6" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                <controls:ResizeThumb Width="7" Height="7" Cursor="SizeNWSE" Margin="-6 -6 0 0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                <controls:ResizeThumb Width="7" Height="7" Cursor="SizeNESW" Margin="0 -6 -6 0" VerticalAlignment="Top" HorizontalAlignment="Right"/>
                <controls:ResizeThumb Width="7" Height="7" Cursor="SizeNESW" Margin="-6 0 0 -6" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
                <controls:ResizeThumb Width="7" Height="7" Cursor="SizeNWSE" Margin="0 0 -6 -6" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
            </Grid>
        </ControlTemplate>

        <!-- Designer Item Template -->
        <ControlTemplate x:Key="DesignerItemTemplate" TargetType="ContentControl">
            <Grid DataContext="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                <controls:MoveThumb Template="{StaticResource MoveThumbTemplate}" Cursor="SizeAll"/>
                <Control Template="{StaticResource ResizeDecoratorTemplate}"/>
                <ContentPresenter Content="{TemplateBinding ContentControl.Content}"/>
            </Grid>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Click="OpenFile_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Image">
                <MenuItem Header="_Filters">
                    <MenuItem Header="Brightness..." Click="Brightness_Click"/>
                    <MenuItem Header="Contrast..." Click="Contrast_Click"/>
                    <MenuItem Header="Gamma..." Click="Gamma_Click"/>
                    <MenuItem Header="Threshold..." Click="Threshold_Click"/>
                    <Separator/>
                    <MenuItem Header="Grayscale" Click="Grayscale_Click"/>
                    <MenuItem Header="Monochrome" Click="Monochrome_Click"/>
                    <MenuItem Header="Invert" Click="Invert_Click"/>
                    <Separator/>
                    <MenuItem Header="Sharpen" Click="Sharpen_Click"/>
                    <MenuItem Header="Smooth" Click="Smooth_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Deskew" Click="Deskew_Click"/>
                <MenuItem Header="Auto Image Correction" Click="AutoCorrect_Click" ToolTip="Auto-deskew and auto-contrast"/>
                <Separator/>
                <MenuItem Header="Undo" Click="UndoImage_Click" InputGestureText="Ctrl+Z"/>
            </MenuItem>
            <MenuItem Header="_AI">
                <MenuItem Header="API Keys..." Click="ApiKeys_Click"/>
                <MenuItem Header="Translation Settings..." Click="TranslationSettings_Click"/>
                <Separator/>
                <MenuItem Header="AI OCR (Current Page)" Click="AiOcrCurrentPage_Click"/>
                <MenuItem Header="AI OCR (All Pages)" Click="AiOcrAllPages_Click"/>
                <Separator/>
                <MenuItem Header="Translate Text" Click="TranslateText_Click"/>
                <Separator/>
                <MenuItem x:Name="menuAiStop" Header="STOP AI OCR" Click="AiOcrStop_Click" IsEnabled="False" Visibility="Collapsed" FontWeight="Bold" Foreground="Red">
                    <MenuItem.Icon>
                        <Image Source="Icons/fatcow/cancel.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Lingosolve Studio" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Label x:Name="statusLabel" Width="180"/>
                    <ProgressBar x:Name="progressBar" Visibility="Hidden" IsIndeterminate="True" Height="18" Width="130"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Grid.Column="1"/>
            <StatusBarItem Grid.Column="2">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Dim:" ToolTip="Image Dimensions"/>
                    <Label x:Name="lblDimensions" Content="0 x 0"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem Grid.Column="3"><Label/></StatusBarItem>
            <Separator Grid.Column="4"/>
            <StatusBarItem Grid.Column="5">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Tokens:"/>
                    <Label x:Name="lblTokens" Content="-"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Grid.Column="6" Margin="1,2,18,2"/>
        </StatusBar>

        <!-- Main Content: Toolbar + 3-Column Layout -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <ToolBarTray Grid.Row="0">
                <ToolBar>
                    <!-- File -->
                    <Button Click="OpenFile_Click" ToolTip="Open Image/PDF">
                        <Image Source="Icons/fatcow/open.png" Width="28" Height="28"/>
                    </Button>
                    <Button Click="PasteImage_Click" ToolTip="Paste Image from Clipboard">
                        <Image Source="Icons/fatcow/image_paste.png" Width="28" Height="28"/>
                    </Button>

                    <!-- Navigation -->
                    <Button x:Name="btnPrev" Click="PrevPage_Click" IsEnabled="False" ToolTip="Previous Page">
                        <Image Source="Icons/fatcow/document_page_previous.png" Width="28" Height="28"/>
                    </Button>
                    <Button x:Name="btnNext" Click="NextPage_Click" IsEnabled="False" ToolTip="Next Page">
                        <Image Source="Icons/fatcow/document_page_next.png" Width="28" Height="28"/>
                    </Button>
                    <TextBox x:Name="txtPageNum" Width="45" IsEnabled="False" VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center" KeyDown="PageNum_KeyDown" Text="0"/>
                    <Label x:Name="lblTotalPages" Content="/ 0" VerticalAlignment="Center"/>
                    <Separator/>

                    <!-- View -->
                    <Button x:Name="btnFitImage" Click="FitImage_Click" IsEnabled="False" ToolTip="Fit Image">
                        <Image Source="Icons/fatcow/zoom_fit.png" Width="28" Height="28"/>
                    </Button>
                    <Button x:Name="btnActualSize" Click="ActualSize_Click" IsEnabled="False" ToolTip="Actual Size">
                        <Image Source="Icons/fatcow/zoom_actual.png" Width="28" Height="28"/>
                    </Button>
                    <Button x:Name="btnZoomIn" Click="ZoomIn_Click" IsEnabled="False" ToolTip="Zoom In">
                        <Image Source="Icons/fatcow/zoom_in.png" Width="28" Height="28"/>
                    </Button>
                    <Button x:Name="btnZoomOut" Click="ZoomOut_Click" IsEnabled="False" ToolTip="Zoom Out">
                        <Image Source="Icons/fatcow/zoom_out.png" Width="28" Height="28"/>
                    </Button>
                    <Button Click="RotateCCW_Click" IsEnabled="False" x:Name="btnRotateCCW" ToolTip="Rotate CCW">
                        <Image Source="Icons/fatcow/rotate_ccw.png" Width="28" Height="28"/>
                    </Button>
                    <Button Click="RotateCW_Click" IsEnabled="False" x:Name="btnRotateCW" ToolTip="Rotate CW">
                        <Image Source="Icons/fatcow/rotate_cw.png" Width="28" Height="28"/>
                    </Button>
                    <Separator/>

                    <!-- AI Actions -->
                    <Button Click="AiOcrCurrentPage_Click" ToolTip="AI OCR (Current Page)">
                        <Image Source="Icons/fatcow/ocr.png" Width="28" Height="28"/>
                    </Button>
                    <Button Click="TranslateText_Click" ToolTip="Translate Text">
                        <Image Source="Icons/fatcow/translation.png" Width="28" Height="28"/>
                    </Button>
                    <Separator/>

                    <!-- Clear -->
                    <Button Click="ClearText_Click" ToolTip="Clear Text">
                        <Image Source="Icons/fatcow/draw_eraser.png" Width="28" Height="28"/>
                    </Button>
                </ToolBar>
            </ToolBarTray>

            <!-- 3-Column Split -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition x:Name="translationColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Image Viewer -->
                <ScrollViewer x:Name="scrollViewer" Grid.Column="0" Background="{x:Static SystemColors.ControlBrush}"
                              HorizontalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                    <controls:ImageCanvas x:Name="imageCanvas" VerticalAlignment="Center"
                                          Width="{Binding ActualWidth, ElementName=imageMain}"
                                          Height="{Binding ActualHeight, ElementName=imageMain}">
                        <ContentControl x:Name="canvasContent" Width="0" Height="0"
                                        Canvas.Top="0" Canvas.Left="0"
                                        Template="{StaticResource DesignerItemTemplate}"
                                        Visibility="Hidden">
                            <Rectangle Fill="Transparent" IsHitTestVisible="False"/>
                        </ContentControl>
                        <Canvas.Background>
                            <VisualBrush>
                                <VisualBrush.Visual>
                                    <Image x:Name="imageMain" Stretch="Fill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Canvas.Background>
                    </controls:ImageCanvas>
                </ScrollViewer>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" ResizeBehavior="PreviousAndNext"/>

                <!-- Middle: OCR Output -->
                <DockPanel Grid.Column="2" LastChildFill="True">
                    <Label DockPanel.Dock="Top" Content="OCR Output" FontWeight="SemiBold" Background="#F5F5F5" Padding="8,4"/>
                    <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="4,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Find (Ctrl+F):" VerticalAlignment="Center" Margin="4,0,6,0" FontSize="11"/>
                            <TextBox x:Name="findTextOCR" Width="160" VerticalContentAlignment="Center" KeyDown="FindTextOCR_KeyDown"/>
                            <Button Content="▲" Click="FindPrevOCR_Click" Padding="6,2" Margin="4,0,0,0" ToolTip="Previous (Shift+Enter)"/>
                            <Button Content="▼" Click="FindNextOCR_Click" Padding="6,2" Margin="2,0,0,0" ToolTip="Next (Enter)"/>
                        </StackPanel>
                    </Border>
                    <TextBox x:Name="textBoxOCR" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True" TextWrapping="Wrap" FontSize="13"/>
                </DockPanel>

                <GridSplitter x:Name="gridSplitterTranslation" Grid.Column="3" Width="5" HorizontalAlignment="Center"
                              ResizeBehavior="PreviousAndNext" Visibility="Collapsed"/>

                <!-- Right: Translation Output (Collapsible) -->
                <DockPanel x:Name="translationPanel" Grid.Column="4" LastChildFill="True" Visibility="Collapsed">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#F5F5F5">
                        <Label Content="Translation" FontWeight="SemiBold" Padding="8,4"/>
                        <Button Content="Save" Click="SaveTranslation_Click" Margin="8,2" Padding="8,2" FontSize="11"/>
                        <Button Content="Clear" Click="ClearTranslation_Click" Margin="4,2" Padding="8,2" FontSize="11"/>
                    </StackPanel>
                    <Border DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="4,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Find (Ctrl+F):" VerticalAlignment="Center" Margin="4,0,6,0" FontSize="11"/>
                            <TextBox x:Name="findTextTranslation" Width="160" VerticalContentAlignment="Center" KeyDown="FindTextTranslation_KeyDown"/>
                            <Button Content="▲" Click="FindPrevTranslation_Click" Padding="6,2" Margin="4,0,0,0" ToolTip="Previous (Shift+Enter)"/>
                            <Button Content="▼" Click="FindNextTranslation_Click" Padding="6,2" Margin="2,0,0,0" ToolTip="Next (Enter)"/>
                        </StackPanel>
                    </Border>
                    <TextBox x:Name="textBoxTranslation" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True" TextWrapping="Wrap" FontSize="13" Background="#FAFAFA"/>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>

    <!-- Loading Overlay -->
    <Grid x:Name="loadingOverlay" Visibility="Collapsed" Background="#80000000">
        <Border Background="White" CornerRadius="8" Padding="30,20" HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="320">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Loading File..." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <ProgressBar x:Name="loadingProgress" IsIndeterminate="True" Height="6" Width="260" Margin="0,0,0,10"/>
                <TextBlock x:Name="loadingStatusText" Text="Please wait..." FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
    </Grid>
</Window>
