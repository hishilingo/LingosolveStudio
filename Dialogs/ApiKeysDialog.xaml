<Window x:Class="LingosolveStudio.Dialogs.ApiKeysDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenRouter API Configuration" Height="280" Width="520" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- OpenRouter API Key -->
        <Label Content="OpenRouter API Key:" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5"/>
        <PasswordBox x:Name="pwdApiKey" Grid.Row="0" Grid.Column="1" Margin="5" Height="25" VerticalContentAlignment="Center"/>
        <TextBox x:Name="txtApiKey" Grid.Row="0" Grid.Column="1" Margin="5" Height="25" VerticalContentAlignment="Center" Visibility="Collapsed"/>
        <ToggleButton x:Name="btnShowKey" Grid.Row="0" Grid.Column="2" Content="&#x1F441;" Width="30" Height="25" Margin="5" FontSize="14" ToolTip="Show/Hide" Click="btnShowKey_Click"/>

        <!-- Model Name -->
        <Label Content="Model Name:" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5"/>
        <TextBox x:Name="txtModelName" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" Height="25" VerticalContentAlignment="Center"
                 ToolTip="e.g. google/gemini-2.0-flash-001, anthropic/claude-sonnet-4, openai/gpt-4o"/>

        <!-- Info text -->
        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Margin="5,15,5,5" TextWrapping="Wrap" Foreground="Gray" FontSize="11">
            <Run Text="OpenRouter.ai provides access to hundreds of AI models via a single API."/>
            <LineBreak/>
            <Run Text="Get your API key at https://openrouter.ai/keys"/>
            <LineBreak/>
            <Run Text="Browse models at https://openrouter.ai/models"/>
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="4" Grid.ColumnSpan="3" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="Save" Width="80" Height="28" Margin="5" Click="btnSave_Click" IsDefault="True"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="80" Height="28" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
