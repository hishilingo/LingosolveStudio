<Window x:Class="LingosolveStudio.Dialogs.AITranslationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Translation Settings" Height="300" Width="420" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Enable Auto-Translation -->
        <CheckBox x:Name="chkEnableTranslation" Grid.Row="0" Grid.ColumnSpan="2"
                  Content="Enable AI Auto-Translation" Margin="0,5" FontWeight="SemiBold"
                  Checked="chkEnableTranslation_Changed" Unchecked="chkEnableTranslation_Changed"/>

        <!-- Target Language -->
        <Label Content="Target Language:" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5"/>
        <ComboBox x:Name="cmbLanguage" Grid.Row="1" Grid.Column="1" Margin="5" Height="25" VerticalContentAlignment="Center"/>

        <!-- Save to File -->
        <CheckBox x:Name="chkSaveToFile" Grid.Row="2" Grid.Column="1"
                  Content="Save output to timestamped file" Margin="5,10"/>

        <!-- Status -->
        <TextBlock x:Name="txtStatus" Grid.Row="3" Grid.ColumnSpan="2" Margin="5,15,5,5" TextWrapping="Wrap" Foreground="Gray" FontSize="11"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="5" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="Save" Width="80" Height="28" Margin="5" Click="btnSave_Click" IsDefault="True"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="80" Height="28" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
