<Window x:Class="LingosolveStudio.Dialogs.SliderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adjust" Height="200" Width="260" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Border Padding="20,0,20,20">
        <StackPanel HorizontalAlignment="Stretch">
            <Label x:Name="label1" Content="Brightness" HorizontalAlignment="Left" Margin="20,5" />
            <Slider x:Name="slider" HorizontalAlignment="Center" Width="170" TickPlacement="BottomRight"
                    ValueChanged="slider_ValueChanged" TickFrequency="20" LargeChange="10"
                    Maximum="100" Minimum="-100" SmallChange="5"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="buttonApply" Content="Apply" Width="75" IsDefault="True" Click="buttonApply_Click"/>
                <Button x:Name="buttonCancel" Content="Cancel" Width="75" IsCancel="True" Margin="10,0,0,0" Click="buttonCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
